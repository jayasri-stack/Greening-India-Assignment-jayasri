# Environment variables for TaskFlow backend

# Database configuration
DATABASE_URL=postgresql://taskflow_user:taskflow_password@localhost:5432/taskflow_db?sslmode=disable

# JWT Secret (generate a random string, minimum 32 characters)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_minimum_32_chars

# Server configuration
PORT=8080

# Environment
ENV=development
